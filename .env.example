# --- Meta WhatsApp Cloud API (production) ---
# APP_BASE_URL=https://your-domain.example
# META_WHATSAPP_ACCESS_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# Optional (defaults to v21.0):
# META_WHATSAPP_API_VERSION=v21.0
#
# Optional template mode for outbound reminders:
# META_WHATSAPP_TEMPLATE_NAME=appointment_reminder
# META_WHATSAPP_TEMPLATE_LANG=ro_RO
# Template body params expected by current backend order:
# 1=customer_name, 2=section, 3=doctor, 4=date, 5=hour
# Button payload IDs expected by webhook: confirm | cancel | reschedule
#
# Inbound replies (Meta → your app):
# Webhook URL: https://YOUR_DOMAIN/api/webhooks/meta/whatsapp
# META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# META_APP_SECRET=your-meta-app-secret
#
# Temporary verbose webhook logging (payload + headers):
# DEBUG_WHATSAPP=true
